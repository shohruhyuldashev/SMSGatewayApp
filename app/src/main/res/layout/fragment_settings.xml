<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CyberBro"
            android:textColor="#3B82F6"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Server Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVER"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Port"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/settingsPortText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8080"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- API Key Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API KEY"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/settingsApiKeyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#CBD5E1"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/generateApiKeyButton"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Generate New Key"
                    android:textSize="13sp"
                    android:backgroundTint="#1E3A5F"
                    android:textColor="#3B82F6"
                    android:layout_marginBottom="12dp" />

                <!-- Lock API Key Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lock API Key"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/apiKeyLockButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="Lock API Key"
                        android:src="@android:drawable/ic_lock_lock"
                        android:backgroundTint="@android:color/transparent"
                        android:tint="#64748B"
                        android:background="?android:attr/selectableItemBackgroundBorderless" />
                </LinearLayout>
            </LinearLayout>

            <!-- Preferences Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREFERENCES"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Auto Start -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto Start on Boot"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                    <Switch
                        android:id="@+id/autoStartSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Dark Mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dark Mode"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                    <Switch
                        android:id="@+id/darkModeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Notifications -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Notifications"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                    <Switch
                        android:id="@+id/notificationsSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Log Retention Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOGS"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Log Retention"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/settingsRetentionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 days"
                        android:textColor="#CBD5E1"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- API Tester Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API TESTER"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/testPhoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone: +99890..."
                    android:inputType="phone"
                    android:textColor="#CBD5E1"
                    android:textColorHint="#475569"
                    android:background="@drawable/card_dark"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/testMessageInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Message..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:textColor="#CBD5E1"
                    android:textColorHint="#475569"
                    android:background="@drawable/card_dark"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM Slot"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:layout_marginEnd="12dp" />
                    <Spinner
                        android:id="@+id/simSlotSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <Button
                    android:id="@+id/sendTestSmsButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Send Test SMS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_start_bg"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- App Version Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_dark"
                android:padding="16dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Version"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/settingsVersionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#CBD5E1"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
