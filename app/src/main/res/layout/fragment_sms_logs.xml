<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CyberBro"
            android:textColor="#3B82F6"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS Logs"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Filter chips row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/filterAllButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="All"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/card_dark"
            android:textColor="#CBD5E1"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/filterSentButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="Sent"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/card_dark"
            android:textColor="#22C55E"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/filterDeliveredButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="Done"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/card_dark"
            android:textColor="#3B82F6"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/filterFailedButton"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:text="Failed"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/card_dark"
            android:textColor="#EF4444" />
    </LinearLayout>

    <!-- Scrollable log list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/smsLogsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading SMS history..."
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.6"
            android:paddingBottom="16dp" />
    </ScrollView>

</LinearLayout>
